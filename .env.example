# ============================================================
# YAI-Excel — Environment Configuration
# Copy this file to .env and fill in your free-tier API keys
# ============================================================

# ---- AI Providers (priority order; first available is used) ----
# Get free keys at:
#   Gemini  — https://aistudio.google.com/apikey
#   Groq    — https://console.groq.com/keys
#   OpenAI  — https://platform.openai.com/api-keys  (optional)
#   Anthropic — https://console.anthropic.com/      (optional)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Vision model preference for the audit pipeline.
# Options: gemini-2.5-flash | gemini-2.5-pro | gpt-4o-mini | claude-3-5-sonnet
VISION_MODEL=gemini-2.5-flash

# ---- Upload Limits ----
MAX_FILE_SIZE_MB=500
MAX_VIDEO_DURATION_SEC=300
ALLOWED_ORIGINS=http://localhost:3000

# ---- Storage ----
STORAGE_PATH=./uploads
OUTPUT_PATH=./outputs

# ---- App Settings ----
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
FRONTEND_PORT=3000

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=YAI-Excel
